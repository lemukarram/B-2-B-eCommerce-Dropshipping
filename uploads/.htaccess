# Disable execution of scripts
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|htm|html|shtml|sh|cgi)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Force download instead of inline execution
<FilesMatch "\.(txt|csv|xls|xlsx)$">
    ForceType application/octet-stream
    Header set Content-Disposition attachment
</FilesMatch>

Options -Indexes